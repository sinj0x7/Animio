# --- Vite (build-time; GitHub Actions uses repo secrets/vars instead) ---
# Public URL path when not hosted at domain root (e.g. GitHub project page: /my-repo/)
# VITE_BASE_PATH=/
# Backend API base for production static hosting (no trailing slash). Must be https:// if the site is https.
# Example: VITE_API_URL=https://api.yourdomain.com/api
# VITE_API_URL=

# Server port (hosting platforms like Railway/Render set this automatically)
PORT=3001

# Set to "production" for deployed builds
NODE_ENV=production

# Comma-separated browser origins allowed to use the API (required when the site is on another host, e.g. GitHub Pages)
# CORS_ORIGINS=https://sinj0x7.github.io

# Comma-separated extra host suffixes for the HLS proxy allowlist (e.g. .cdn.example.com,stream.foo.net)
# HLS_ALLOWED_HOSTS=

# Log each HTTP request to stdout (1 or true)
# REQUEST_LOG=
